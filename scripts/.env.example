# Credential template — copy this file to scripts/.env and fill in real values
# Set RISK_ENV_PATH env var to override the default location:
#   Windows: set RISK_ENV_PATH=C:\path\to\your\credentials.env

user=YOUR_THAIBMA_USERNAME
pass=YOUR_THAIBMA_PASSWORD

# SQL Server — update DB_MAIN_SERVER in scripts/config.py with the actual server name
# Uses Windows Authentication (Trusted_Connection=yes) — no password needed here
